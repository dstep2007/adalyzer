{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Next.js: dev (turbopack)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --turbopack",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Next.js: dev (no browser)",
      "type": "node-terminal",
      "request": "launch",
      "command": "npm run dev -- --turbopack",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Next.js: debug server-side",
      "type": "node-terminal",
      "request": "launch",
      "command": "NODE_OPTIONS='--inspect' npm run dev -- --turbopack",
      "cwd": "${workspaceFolder}",
      "serverReadyAction": {
        "pattern": "- Local:.+(https?://\\S+)",
        "uriFormat": "%s",
        "action": "debugWithChrome"
      }
    },
    {
      "name": "Next.js: debug client-side",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:3000"
    }
  ]
}
